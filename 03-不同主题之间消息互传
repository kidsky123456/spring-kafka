### 第一套系统（项目 A：发起请求与接收响应）
**1. 配置文件 `application.yml`**
```yaml
server:
  port: 8081
spring:
  kafka:
    bootstrap-servers: 127.0.0.1:9092 # 同一套Kafka环境
    producer:
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.springframework.kafka.support.serializer.JsonSerializer
    consumer:
      group-id: project-a-response-group # 注意：消费者组不要和项目B冲突
      auto-offset-reset: earliest
      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      value-deserializer: org.springframework.kafka.support.serializer.JsonDeserializer
      properties:
        spring.json.trusted.packages: "*" # 允许反序列化的包
```
**2. 生产者：发送请求**
```java
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Service;
import java.util.UUID;
@Service
public class RequestProducer {
    private final KafkaTemplate<String, MessageDTO> kafkaTemplate;
    public RequestProducer(KafkaTemplate<String, MessageDTO> kafkaTemplate) {
        this.kafkaTemplate = kafkaTemplate;
    }
    public void sendRequest(String payload) {
        MessageDTO dto = new MessageDTO();
        dto.setMessageId(UUID.randomUUID().toString()); // 生成唯一ID
        dto.setPayload(payload);
        dto.setTimestamp(System.currentTimeMillis());
        // 发送到请求 Topic，以 messageId 作为 Key（保证同一消息进入同一分区，可选）
        kafkaTemplate.send("topic.request", dto.getMessageId(), dto);
        System.out.println("项目A - 发送请求: " + dto.getMessageId());
    }
}
```
**3. 消费者：接收第二套系统处理后的结果**
```java
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;
@Component
public class ResponseConsumer {
    @KafkaListener(topics = "topic.response", groupId = "project-a-response-group")
    public void receiveResponse(MessageDTO dto) {
        System.out.println("项目A - 收到项目B的处理结果: ");
        System.out.println("关联ID: " + dto.getMessageId());
        System.out.println("处理结果数据: " + dto.getPayload());
        
        // TODO: 在这里可以根据 messageId 找到原来发起请求的上下文（比如存在ThreadLocal或Redis中），将结果返回给前端
    }
}
```
**4. 提供一个测试接口**
```java
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;
@RestController
public class ApiController {
    private final RequestProducer requestProducer;
    public ApiController(RequestProducer requestProducer) {
        this.requestProducer = requestProducer;
    }
    @GetMapping("/send")
    public String send(@RequestParam String msg) {
        requestProducer.sendRequest(msg);
        return "请求已发送，请观察控制台接收结果";
    }
}
```
