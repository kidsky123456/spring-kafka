### 第二套系统（项目 B：接收请求，处理并返回结果）
**1. 配置文件 `application.yml`**
```yaml
server:
  port: 8082
spring:
  kafka:
    bootstrap-servers: 127.0.0.1:9092 # 同一套Kafka环境
    consumer:
      group-id: project-b-request-group # 独立的消费者组
      auto-offset-reset: earliest
      key-deserializer: org.apache.kafka.common.serialization.StringDeserializer
      value-deserializer: org.springframework.kafka.support.serializer.JsonDeserializer
      properties:
        spring.json.trusted.packages: "*"
    producer:
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.springframework.kafka.support.serializer.JsonSerializer
```
**2. 消费者：接收第一套系统的请求**
```java
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.stereotype.Component;
@Component
public class RequestListener {
    private final ResponseProducer responseProducer;
    public RequestListener(ResponseProducer responseProducer) {
        this.responseProducer = responseProducer;
    }
    @KafkaListener(topics = "topic.request", groupId = "project-b-request-group")
    public void handleRequest(MessageDTO dto) {
        System.out.println("项目B - 收到项目A的请求: " + dto.getMessageId());
        
        // 模拟一系列复杂的业务处理（耗时操作）
        try {
            Thread.sleep(2000); 
        } catch (InterruptedException e) {
            throw new RuntimeException(e);
        }
        
        String processedResult = "【已处理】" + dto.getPayload();
        
        // 调用本项目的生产者，把结果发回去
        responseProducer.sendResponse(dto.getMessageId(), processedResult);
    }
}
```
**3. 生产者：将处理结果发回给第一套系统**
```java
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Service;
@Service
public class ResponseProducer {
    private final KafkaTemplate<String, MessageDTO> kafkaTemplate;
    public ResponseProducer(KafkaTemplate<String, MessageDTO> kafkaTemplate) {
        this.kafkaTemplate = kafkaTemplate;
    }
    public void sendResponse(String originalMessageId, String resultPayload) {
        MessageDTO dto = new MessageDTO();
        dto.setMessageId(originalMessageId); // 必须把原来的ID传回去，项目A才能对上号
        dto.setPayload(resultPayload);
        dto.setTimestamp(System.currentTimeMillis());
        kafkaTemplate.send("topic.response", dto.getMessageId(), dto);
        System.out.println("项目B - 已发送处理结果: " + dto.getMessageId());
    }
}
```
